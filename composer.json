{
    "name": "bitarun/laravel-notification-service",
    "description": "Notification service for Laravel applications with support for Email and SMS, including queue support.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "notification", "sms", "email", "queue"],
    "homepage": "https://github.com/bitarun/laravel-notification-service",
    "autoload": {
        "psr-4": {
            "Bitarun\\LaravelNotificationService\\": "src/"
        }
    },
    "authors": [
        {
            "name": "bitabadrkhani",
            "email": "bita.badrkhani@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bitarun\\LaravelNotificationService\\NotificationServiceProvider"
            ]
        }
    }
}